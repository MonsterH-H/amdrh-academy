# ============================================
# AMDRH Academy — Configuration Production
# ============================================

# ── Database (Neon PostgreSQL) ────────────
# DATABASE_URL      → Pooler URL (pour l'application en production)
# DIRECT_URL        → Connection directe (pour Prisma migrations/seeding)
# NEON_DATABASE_URL → URL dédiée pour Prisma schema (évite les conflits env shell)
DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-empty-meadow-amjci1oh-pooler.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-empty-meadow-amjci1oh.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require"
NEON_DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-empty-meadow-amjci1oh-pooler.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ── NextAuth v4 ────────────────────────────
NEXTAUTH_URL="https://amdrh-academy.vercel.app"
NEXTAUTH_SECRET="your-nextauth-secret-here"

# ── Application ────────────────────────────
NEXT_PUBLIC_APP_NAME="Académie AMDRH"
NEXT_PUBLIC_APP_URL="https://amdrh-academy.vercel.app"

# ── Email (Resend) ──────────────────────────
# Set RESEND_API_KEY to send real emails. Leave empty for console fallback.
RESEND_API_KEY=""
EMAIL_FROM="noreply@amdrh-academy.ma"
