# ============================================
# AMDRH Academy — Vercel Environment Variables
# ============================================
# ⚠️  IMPORTANT: Copy ALL these variables into
# Vercel → Settings → Environment Variables
# Then redeploy your app.
# ============================================

# ── Database (Neon PostgreSQL) ────────────
# OBLIGATOIRE - URL de connexion à votre base Neon
# Trouvez cette URL dans votre dashboard Neon → Connection string → Pooled
DATABASE_URL=postgresql://neondb_owner:npg_BJ1sINw6ChyU@ep-empty-meadow-amjci1oh-pooler.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require

# URL directe pour les migrations Prisma (optionnel mais recommandé)
DIRECT_URL=postgresql://neondb_owner:npg_BJ1sINw6ChyU@ep-empty-meadow-amjci1oh.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── NextAuth v4 ────────────────────────────
# OBLIGATOIRE - Secret pour les sessions JWT
# Généré avec: openssl rand -hex 32
NEXTAUTH_SECRET=77cadc0af581ebe11076d79c2370e4ce1da5ad7eb504576e862cabd6edf7a063

# URL de votre app sur Vercel
NEXTAUTH_URL=https://amdrhacademy.vercel.app

# ── UploadThing (fichiers) ──────────────────
# OBLIGATOIRE si vous utilisez l'upload de fichiers
UPLOADTHING_TOKEN=your_uploadthing_token_here

# ── Email (Resend) ──────────────────────────
# Laissez vide = pas d'envoi d'emails (console log à la place)
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# ── Realtime (WebSocket) ────────────────────
# false = désactivé (recommandé pour Vercel)
NEXT_PUBLIC_ENABLE_REALTIME=false

# ── Application ────────────────────────────
NEXT_PUBLIC_APP_NAME=Académie AMDRH
NEXT_PUBLIC_APP_URL=https://amdrhacademy.vercel.app

# ============================================
# APRÈS LE DÉPLOIEMENT SUR VERCEL:
# ============================================
# 1. Une fois les variables ajoutées, déployez
# 2. Appelez cette URL pour créer les comptes:
#    POST https://amdrhacademy.vercel.app/api/auth/seed
#    (utilisez curl, Postman, ou un navigateur)
#
# 3. Connectez-vous avec:
#    Email:    admin@amdrh.ma
#    Password: Admin@2024!
#
# Comptes disponibles:
#   - admin@amdrh.ma       (Admin)      → Admin@2024!
#   - formateur@amdrh.ma    (Formateur)  → Formateur@2024!
#   - arbitre@amdrh.ma      (Arbitre)    → Arbitre@2024!
#   - entraineur@amdrh.ma   (Entraîneur) → Entraineur@2024!
#   - joueur@amdrh.ma       (Joueur)     → Joueur@2024!
# ============================================
