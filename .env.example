# ============================================
# AMDRH Academy - Configuration
# ============================================

# Database (Neon PostgreSQL)
# DATABASE_URL  -> Connection pooler URL (for application)
# DIRECT_URL    -> Direct connection URL (for migrations)
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/amdrh_db?sslmode=require&pool_size=10"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/amdrh_db?sslmode=require"

# NextAuth Configuration
NEXTAUTH_URL="https://your-domain.com"
NEXTAUTH_SECRET="your-secret-key-min-32-chars"

# App Configuration
NEXT_PUBLIC_APP_NAME="Académie AMDRH"
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# File Upload (optional - for S3/Cloud storage)
# UPLOAD_BUCKET=""
# UPLOAD_REGION=""
# UPLOAD_ACCESS_KEY=""
# UPLOAD_SECRET_KEY=""
