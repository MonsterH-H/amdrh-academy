generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// UTILISATEURS
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  nom           String
  prenom        String
  telephone     String?
  avatar        String?
  role          String    @default("ARBITRE") // ADMIN, FORMATEUR, ARBITRE, ENTRAINEUR, JOUEUR
  licenceNumber String?   @unique
  club          String?
  region        String?
  bio           String?
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  coursesCreated    Course[]          @relation("CourseInstructor")
  enrollments       Enrollment[]
  quizAttempts      QuizAttempt[]
  certificates      Certificate[]
  userBadges        UserBadge[]
  sentMessages      Message[]       @relation("SentMessages")
  receivedMessages  Message[]       @relation("ReceivedMessages")
  conversationParticipants ConversationParticipant[]
  notifications     Notification[]
  uploadedResources Resource[]       @relation("ResourceUploader")
  forumDiscussions  ForumDiscussion[] @relation("ForumAuthor")
  forumReplies      ForumReply[]      @relation("ForumReplyAuthor")
  auditLogs         AuditLog[]        @relation("AuditLogUser")
  announcements     Announcement[]    @relation("AnnouncementAuthor")
}

// ============================================
// COURS & CONTENU
// ============================================

model Course {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  description   String
  coverImage    String?
  category      String    @default("ARBITRAGE") // ARBITRAGE, ENTRAINEMENT, JOUEURS, ADMINISTRATION
  difficulty    String    @default("DEBUTANT") // DEBUTANT, INTERMEDIAIRE, AVANCE, EXPERT
  status        String    @default("BROUILLON") // BROUILLON, EN_REVISION, VALIDE, PUBLIE, ARCHIVE
  duration      Int       @default(0)
  isCertifying  Boolean   @default(false)
  passingScore  Int       @default(70)
  maxAttempts   Int       @default(3)
  order         Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  instructorId   String?
  instructor     User?            @relation("CourseInstructor", fields: [instructorId], references: [id])
  sections       Section[]
  quiz           Quiz?
  enrollments    Enrollment[]
  learningPaths  LearningPathCourse[]
  resources      Resource[]       @relation("CourseResources")
  forumDiscussions ForumDiscussion[]
}

model Section {
  id        String  @id @default(cuid())
  title     String
  order     Int     @default(0)
  courseId  String
  course    Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons   Lesson[]
}

model Lesson {
  id          String  @id @default(cuid())
  title       String
  type        String  @default("TEXTE") // VIDEO, PDF, TEXTE, INTERACTIF
  content     String  @default("")
  duration    Int     @default(0)
  order       Int     @default(0)
  sectionId   String
  section     Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  progress    LessonProgress[]
}

// ============================================
// INSCRIPTIONS & PROGRESSION
// ============================================

model Enrollment {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId      String
  course        Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  status        String    @default("en_cours") // en_cours, termine, abandonne
  progress      Float     @default(0)
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  lastAccessAt  DateTime  @default(now())

  lessonProgress LessonProgress[]

  @@unique([userId, courseId])
}

model LessonProgress {
  id               String   @id @default(cuid())
  enrollmentId     String
  enrollment       Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lessonId         String
  lesson           Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completed        Boolean   @default(false)
  lastPosition     Int       @default(0)
  timeSpent        Int       @default(0)
  watchPercentage  Float     @default(0)
  scrollPercentage Float     @default(0)
  completionTrigger String   @default("manual")
  viewedAt         DateTime  @default(now())
  completedAt      DateTime?

  @@unique([enrollmentId, lessonId])
}

// ============================================
// QUIZ & ÉVALUATIONS
// ============================================

model Quiz {
  id               String  @id @default(cuid())
  title            String
  description      String?
  courseId         String  @unique
  course           Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  duration         Int     @default(30)
  passingScore     Int     @default(70)
  shuffleQuestions Boolean @default(true)
  showAnswers      Boolean @default(true)
  maxAttempts      Int     @default(3)
  createdAt        DateTime @default(now())

  questions     Question[]
  attempts      QuizAttempt[]
}

model Question {
  id            String  @id @default(cuid())
  quizId        String
  quiz          Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)
  text          String
  type          String  @default("QCM_SIMPLE") // QCM_SIMPLE, QCM_MULTIPLE, VRAI_FAUX
  options       String  @default("[]")
  correctAnswer String  @default("[]")
  explanation   String?
  points        Int     @default(1)
  order         Int     @default(0)

  answers       QuizAnswer[]
}

model QuizAttempt {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId      String
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  status      String   @default("EN_COURS") // EN_COURS, SOUMIS, REUSSI, ECHOUE
  score       Int      @default(0)
  maxScore    Int      @default(0)
  duration    Int      @default(0)
  startedAt   DateTime @default(now())
  submittedAt DateTime?

  answers     QuizAnswer[]
}

model QuizAnswer {
  id             String     @id @default(cuid())
  attemptId      String
  attempt        QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId     String
  question       Question   @relation(fields: [questionId], references: [id])
  selectedAnswer String     @default("[]")
  isCorrect      Boolean?
  pointsEarned   Int        @default(0)
}

// ============================================
// CERTIFICATS & BADGES
// ============================================

model Certificate {
  id            String   @id @default(cuid())
  code          String   @unique
  type          String   @default("CERTIFICAT") // ATTESTATION, CERTIFICAT_COMPLETION, DIPLOME
  status        String   @default("ACTIVE") // ACTIVE, REVOKED, SUSPENDED
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  courseId      String
  courseTitle   String
  userName      String
  userLicence   String?
  score         Int
  maxScore      Int
  issuedAt      DateTime @default(now())
  expiresAt     DateTime?
  revokedAt     DateTime?
  revokeReason  String?
  qrCodeUrl     String?
  verifiedBy    String?
  pdfUrl        String?
}

model Badge {
  id          String   @id @default(cuid())
  name        String
  description String
  icon        String
  level       String   @default("BRONZE") // BRONZE, ARGENT, OR, PLATINE
  criteria    String
  createdAt   DateTime @default(now())

  userBadges  UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt  DateTime @default(now())

  @@unique([userId, badgeId])
}

// ============================================
// LEARNING PATHS
// ============================================

model LearningPath {
  id             String   @id @default(cuid())
  title          String
  description    String
  slug           String   @unique
  targetRole     String   @default("ARBITRE") // UserRole enum as string
  mode           String   @default("sequentiel") // sequentiel, flexible, hybride
  isMandatory    Boolean  @default(false)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  courses        LearningPathCourse[]
  enrollments    LearningPathEnrollment[]
}

model LearningPathCourse {
  id              String       @id @default(cuid())
  learningPathId  String
  learningPath    LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  courseId        String
  course          Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  order           Int          @default(0)
  isRequired      Boolean      @default(true)
  minScore        Int          @default(70)

  @@unique([learningPathId, courseId])
}

model LearningPathEnrollment {
  id               String       @id @default(cuid())
  userId           String
  learningPathId   String
  learningPath     LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  progress         Float        @default(0)
  currentCourseOrder Int         @default(0)
  status           String       @default("en_cours")
  startedAt        DateTime     @default(now())
  completedAt      DateTime?

  @@unique([userId, learningPathId])
}

// ============================================
// MESSAGERIE
// ============================================

model Conversation {
  id        String                    @id @default(cuid())
  subject   String?
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt

  participants ConversationParticipant[]
  messages    Message[]
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime?
  joinedAt       DateTime     @default(now())

  @@unique([userId, conversationId])
}

model Message {
  id             String       @id @default(cuid())
  content        String
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId     String?
  receiver       User?        @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: SetNull)
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   @default("SYSTEME") // COURS, CERTIFICAT, MESSAGE, QUIZ, BADGE, SYSTEME
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ============================================
// RESSOURCES & MÉDIATHÈQUE
// ============================================

model Resource {
  id            String   @id @default(cuid())
  title         String
  description   String?
  fileName      String
  filePath      String
  fileSize      Int      @default(0)
  fileType      String   @default("AUTRE") // VIDEO, PDF, IMAGE, DOCUMENT, AUDIO, ARCHIVE, AUTRE
  mimeType      String?
  category      String   @default("AUTRE") // SUPPORT_COURS, RESSOURCE_ANNEXE, EVALUATION, MEDIA_COURS, AUTRE
  isDownloadable Boolean  @default(true)
  downloadCount Int      @default(0)
  order         Int      @default(0)

  courseId      String?
  course        Course?  @relation("CourseResources", fields: [courseId], references: [id], onDelete: SetNull)
  sectionId     String?
  lessonId      String?

  uploadedById  String
  uploadedBy    User     @relation("ResourceUploader", fields: [uploadedById], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============================================
// SYNCHRONISATION FÉDÉRATION
// ============================================

model FederationSync {
  id               String   @id @default(cuid())
  type             String   // licence_sync, certification_sync
  status           String   @default("EN_ATTENTE") // EN_ATTENTE, EN_COURS, TERMINE, ERREUR
  totalRecords     Int      @default(0)
  processedRecords Int      @default(0)
  errorRecords     Int      @default(0)
  errorMessage     String?
  startedAt        DateTime @default(now())
  completedAt      DateTime?
  triggeredBy      String
}

// ============================================
// PASSWORD RESET
// ============================================

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

// ============================================
// EMAIL VERIFICATION
// ============================================

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

// ============================================
// ANNONCES
// ============================================

model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String
  type        String   @default("INFO") // INFO, URGENT, EVENEMENT, FORMATION, RESULTAT
  targetRoles String   @default("[]")   // JSON array of roles who should see this
  isPinned    Boolean  @default(false)
  isPublished Boolean  @default(true)
  expiresAt   DateTime?
  authorId    String
  author      User     @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished])
}

// ============================================
// FORUM DE DISCUSSION
// ============================================

model ForumDiscussion {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation("ForumAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  title       String
  content     String
  isPinned    Boolean  @default(false)
  isResolved  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  replies     ForumReply[]

  @@index([courseId])
  @@index([authorId])
}

model ForumReply {
  id            String   @id @default(cuid())
  discussionId  String
  discussion    ForumDiscussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  authorId      String
  author        User     @relation("ForumReplyAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  content       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([discussionId])
  @@index([authorId])
}

// ============================================
// AUDIT LOGS
// ============================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("AuditLogUser", fields: [userId], references: [id], onDelete: Cascade)
  action    String   // create, update, delete, login, logout, view
  entity    String   // course, user, quiz, certificate, etc.
  entityId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}

// ============================================
// PERMISSIONS
// ============================================

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique           // e.g. "courses.view", "users.manage"
  description String   @default("")
  module      String   @default("general") // e.g. "courses", "users", "quizzes", "admin"
  action      String   @default("view")   // view, create, edit, delete, manage
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]
}

model RolePermission {
  id           String     @id @default(cuid())
  role         String     // ADMIN, FORMATEUR, ARBITRE, ENTRAINEUR, JOUEUR
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([role, permissionId])
}
